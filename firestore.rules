rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Public content (anyone can read) ─────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promoBanners/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /collaborations/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /translations/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Live sessions & events (authenticated users) ──────────────────────────
    match /Live_sessions/{sessionId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /Live_events/{eventId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /chat/{messageId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // ── Global reels / stories ────────────────────────────────────────────────
    match /global_reels/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /stories/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Collection group wildcard rules (REQUIRED for collectionGroup queries) ──
    // These cover any 'works' or 'comments' subcollection at any depth
    match /{path=**}/works/{workId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{path=**}/notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{path=**}/Live_sessions/{sessionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();       // any signed-in user can read profiles (for feed, friends, etc.)
      allow write: if isOwner(userId) || isAdmin();

      match /works/{workId} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }

      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isSignedIn();
      }

      match /friendRequests/{reqId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isSignedIn();
      }
    }

    // ── Friend requests (top-level) ───────────────────────────────────────────
    match /friendRequests/{reqId} {
      allow read, write: if isSignedIn();
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isSignedIn();
    }

    // ── Cart ──────────────────────────────────────────────────────────────────
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Shipments (two spellings used in the codebase) ────────────────────────
    match /scans/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /shipments/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /Shipments/{document=**} {
      allow read, write: if isSignedIn();
    }

    // ── Delivery / drivers ────────────────────────────────────────────────────
    match /deliveries/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /drivers/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Messages & chats ──────────────────────────────────────────────────────
    match /direct_chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── Socials & feed ────────────────────────────────────────────────────────
    match /socials/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /social_feeds/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── KYC ───────────────────────────────────────────────────────────────────
    match /kyc/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Scratch & win ─────────────────────────────────────────────────────────
    match /scratchCards/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /scratchWins/{document=**} {
      allow read, write: if isSignedIn();
    }

    // ── Support / admin chat ──────────────────────────────────────────────────
    match /support_chats/{document=**} {
      allow read, write: if isSignedIn();
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }

    // ── Wallets (COD Financial Model) ─────────────────────────────────────────
    // A wallet belongs to either a brand owner, delivery company, or the platform.
    // The owner and admins can read a wallet.
    // Only admins (or server-side via Cloud Functions) can perform balance updates.
    match /wallets/{walletId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.userId == request.auth.uid) ||
        (isSignedIn() && resource.data.ownerId == request.auth.uid);
      // Create is allowed for signed-in users (getOrCreateWallet bootstrap)
      allow create: if isSignedIn();
      // Balance fields can only be modified by admin – EXCEPT the owner can
      // decrease their own balance (for withdrawal requests).
      allow update: if isAdmin() ||
        (isSignedIn() && (resource.data.userId == request.auth.uid || resource.data.ownerId == request.auth.uid) &&
          // Owner may decrease balance (withdrawal) but not increase it
          request.resource.data.balance <= resource.data.balance &&
          // Owner may NOT touch totalEarned or totalWithdrawn
          request.resource.data.totalEarned == resource.data.totalEarned &&
          request.resource.data.totalWithdrawn == resource.data.totalWithdrawn);
      allow delete: if isAdmin();
    }

    // ── COD Transactions (Immutable Ledger) ────────────────────────────────────
    // Transactions are append-only records of financial movements.
    // Anyone who was a sender, brand owner, or customer can read their own transactions.
    // Only admin or trusted service accounts update status (settlement).
    match /transactions/{txId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.brandId == request.auth.uid) ||
        (isSignedIn() && resource.data.customerId == request.auth.uid) ||
        (isSignedIn() && resource.data.userId == request.auth.uid) ||
        (isSignedIn() && resource.data.driverId == request.auth.uid);
      // Anyone signed in can create a pending COD record
      allow create: if isSignedIn();
      // Only admins can update (e.g. settle / refund)
      allow update: if isAdmin();
      allow delete: if false; // Ledger records are never deleted
    }

    // ── Delivery Companies ─────────────────────────────────────────────────────
    // Admin manages delivery company profiles.
    // All signed-in users can read (needed for auto-assignment).
    match /deliveryCompanies/{companyId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Delivery Company Wallets (sub-collection) ──────────────────────────────
    match /deliveryCompanies/{companyId}/walletHistory/{entryId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ── Withdrawal Requests ───────────────────────────────────────────────────
    // Brands can create withdrawal requests for themselves.
    // Only admins can approve or reject (update status).
    match /withdrawal_requests/{requestId} {
      allow read: if isAdmin() ||
        (isSignedIn() && resource.data.brandId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if false; // Never delete withdrawal records
    }

    // ── Vendor Applications ─────────────────────────────────────────────────────
    // Users can create vendor applications. Admins can read and update.
    match /vendorApplications/{applicationId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── Gifts ────────────────────────────────────────────────────────────────────
    match /gifts/{giftId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Payment System Collections ──────────────────────────────────────────────
    
    // Delivery Zones - managed by admin, readable by all for fee calculation
    match /delivery_zones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Delivery Persons - managed by admin and delivery company
    match /delivery_persons/{personId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && resource.data.userId == request.auth.uid);
    }
    
    // Delivery Companies - managed by admin
    match /delivery_companies/{companyId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    
    // Payouts - user can read their own, admin can manage all
    match /payouts/{payoutId} {
      allow read: if isAdmin() || 
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }
    
    // Refunds - user can read their own orders, admin manages all
    match /refunds/{refundId} {
      allow read: if isAdmin() || 
        (isSignedIn() && resource.data.requestedBy == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin();
    }

    // ── History ─────────────────────────────────────────────────────────────────
    match /history/{document=**} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ── Treasure Hunt ───────────────────────────────────────────────────────────
    // Treasure Campaigns - Admin only for write, public for read
    match /treasure_campaigns/{campaignId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Treasure Locations - Public read, admin write
    match /treasure_locations/{locationId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Treasure Participations - User can read/write own, admin can read all
    match /treasure_participations/{participationId} {
      allow read: if isAdmin() || 
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isSignedIn();
      allow update: if isAdmin() || 
        (isSignedIn() && resource.data.userId == request.auth.uid);
    }

    // Treasure Scans - Admin read, user create
    match /treasure_scans/{scanId} {
      allow read: if isAdmin();
      allow create: if isSignedIn();
    }

    // Treasure Rewards - User can read own
    match /treasure_rewards/{rewardId} {
      allow read: if isAdmin() || 
        (isSignedIn() && resource.data.userId == request.auth.uid);
      allow create: if isAdmin();
    }
  }
}