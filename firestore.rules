rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // ── Public content (anyone can read) ─────────────────────────────────────
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /categories/{categoryId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /brands/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /ads/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /banners/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /promoBanners/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /collaborations/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /settings/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /translations/{key} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /coupons/{document=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ── Live sessions & events (authenticated users) ──────────────────────────
    match /Live_sessions/{sessionId} {
      allow read: if true;
      allow write: if isSignedIn();

      match /Live_events/{eventId} {
        allow read: if true;
        allow write: if isSignedIn();
      }

      match /chat/{messageId} {
        allow read: if true;
        allow write: if isSignedIn();
      }
    }

    // ── Global reels / stories ────────────────────────────────────────────────
    match /global_reels/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /stories/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── Collection group wildcard rules (REQUIRED for collectionGroup queries) ──
    // These cover any 'works' or 'comments' subcollection at any depth
    match /{path=**}/works/{workId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{path=**}/comments/{commentId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /{path=**}/notifications/{notificationId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    match /{path=**}/Live_sessions/{sessionId} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── User profiles ─────────────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isSignedIn();       // any signed-in user can read profiles (for feed, friends, etc.)
      allow write: if isOwner(userId) || isAdmin();

      match /works/{workId} {
        allow read: if true;
        allow write: if isOwner(userId) || isAdmin();
      }

      match /transactions/{txId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isSignedIn();
      }

      match /friendRequests/{reqId} {
        allow read: if isOwner(userId) || isAdmin();
        allow write: if isSignedIn();
      }
    }

    // ── Friend requests (top-level) ───────────────────────────────────────────
    match /friendRequests/{reqId} {
      allow read, write: if isSignedIn();
    }

    // ── Orders ────────────────────────────────────────────────────────────────
    match /orders/{orderId} {
      allow create: if isSignedIn();
      allow read: if isSignedIn();
      allow update: if isSignedIn();
    }

    // ── Cart ──────────────────────────────────────────────────────────────────
    match /carts/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Shipments (two spellings used in the codebase) ────────────────────────
    match /scans/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /shipments/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /Shipments/{document=**} {
      allow read, write: if isSignedIn();
    }

    // ── Delivery / drivers ────────────────────────────────────────────────────
    match /deliveries/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /drivers/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Messages & chats ──────────────────────────────────────────────────────
    match /direct_chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    match /chats/{chatId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // ── Socials & feed ────────────────────────────────────────────────────────
    match /socials/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    match /social_feeds/{document=**} {
      allow read: if true;
      allow write: if isSignedIn();
    }

    // ── KYC ───────────────────────────────────────────────────────────────────
    match /kyc/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Notifications ─────────────────────────────────────────────────────────
    match /notifications/{document=**} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // ── Scratch & win ─────────────────────────────────────────────────────────
    match /scratchCards/{document=**} {
      allow read, write: if isSignedIn();
    }

    match /scratchWins/{document=**} {
      allow read, write: if isSignedIn();
    }

    // ── Support / admin chat ──────────────────────────────────────────────────
    match /support_chats/{document=**} {
      allow read, write: if isSignedIn();
    }

    // ── Reviews ───────────────────────────────────────────────────────────────
    match /reviews/{reviewId} {
      allow read: if true;
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update, delete: if isSignedIn() && (request.auth.uid == resource.data.userId || isAdmin());
    }
  }
}