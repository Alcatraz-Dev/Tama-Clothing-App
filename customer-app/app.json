{
  "expo": {
    "name": "Bey3a",
    "slug": "tama-clothing",
    "scheme": "tama-clothing",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/expo-icons/icon.png",
    "splash": {
      "image": "./assets/expo-icons/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#010100"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.alcatrazdev.tamaclothing",
      "entitlements": {
        "com.apple.security.application-groups": [
          "group.com.alcatrazdev.tamaclothing"
        ]
      },
      "infoPlist": {
        "CFBundleDisplayName": "Bey3a",
        "ITSAppUsesNonExemptEncryption": false,
        "NSCameraUsageDescription": "This app needs camera access to take photos and record videos.",
        "NSMicrophoneUsageDescription": "This app needs microphone access to record videos.",
        "NSLocationWhenInUseUsageDescription": "This app needs location access to track your delivery in real-time.",
        "NSSupportsLiveActivities": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/expo-icons/splash-icon.png",
        "backgroundColor": "#010100"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.alcatrazdev.tamaclothing",
      "permissions": [
        "ACCESS_WIFI_STATE",
        "ACCESS_NETWORK_STATE",
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "BLUETOOTH",
        "BLUETOOTH_CONNECT"
      ]
    },
    "web": {
      "favicon": "./assets/expo-icons/favicon.png"
    },
    "extra": {
      "eas": {
        "projectId": "3d48b864-f404-40a3-a69d-ac13e74fe8a2"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/3d48b864-f404-40a3-a69d-ac13e74fe8a2"
    },
    "plugins": [
      [
        "@stream-io/video-react-native-sdk",
        {
          "iOSEnableMultitaskingCameraAccess": true,
          "androidPictureInPicture": true
        }
      ],
      [
        "@config-plugins/react-native-webrtc",
        {
          "cameraPermission": "$(PRODUCT_NAME) requires camera access in order to capture and transmit video",
          "microphonePermission": "$(PRODUCT_NAME) requires microphone access in order to capture and transmit audio"
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera for photos and videos.",
          "microphonePermission": "Allow $(PRODUCT_NAME) to access your microphone for video recording.",
          "recordAudioAndroid": true
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/expo-icons/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID."
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "deploymentTarget": "16.0"
          },
          "android": {
            "extraProguardRules": ""
          }
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos.",
          "savePhotosPermission": "Allow $(PRODUCT_NAME) to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ],
      "expo-font",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location for real-time delivery tracking."
        }
      ],
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#010100",
          "image": "./assets/expo-icons/splash-icon.png",
          "dark": {
            "image": "./assets/expo-icons/splash-icon.png",
            "backgroundColor": "#010100"
          },
          "light": {
            "image": "./assets/expo-icons/splash-icon.png",
            "backgroundColor": "#010100"
          },
          "imageWidth": 200
        }
      ],
      "expo-video",
      "expo-audio",
      "expo-image",
      "expo-router",
      "expo-sharing",
      [
        "expo-widgets",
        {
          "widgets": [
            {
              "name": "CartWidget",
              "displayName": "Cart",
              "description": "View your shopping cart at a glance",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge",
                "accessoryRectangular",
                "accessoryInline",
                "accessoryCircular"
              ]
            },
            {
              "name": "DealsWidget",
              "displayName": "Deals",
              "description": "View today's deals",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge",
                "accessoryRectangular",
                "accessoryInline",
                "accessoryCircular"
              ]
            },
            {
              "name": "OrderTrackingWidget",
              "displayName": "Order Tracking",
              "description": "Track your latest order",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge",
                "accessoryRectangular",
                "accessoryInline",
                "accessoryCircular"
              ]
            },
            {
              "name": "RecommendationsWidget",
              "displayName": "Recommendations",
              "description": "Personalized recommendations",
              "supportedFamilies": [
                "systemSmall",
                "systemMedium",
                "systemLarge",
                "accessoryRectangular",
                "accessoryInline",
                "accessoryCircular"
              ]
            }
          ],
          "liveActivities": [
            {
              "name": "OrderTrackingActivity"
            }
          ],
          "bundleIdentifier": "com.alcatrazdev.tamaclothing.ExpoWidgetsTarget",
          "groupIdentifier": "group.com.alcatrazdev.tamaclothing"
        }
      ],
      [
        "react-native-android-widget",
        {
          "widgets": [
            {
              "name": "CartWidget",
              "label": "Bey3a Cart",
              "description": "View your shopping cart",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "CartWidgetLarge",
              "label": "Bey3a Cart (Large)",
              "description": "Large view of your shopping cart",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "DealsWidget",
              "label": "Bey3a Deals",
              "description": "Today's hot deals",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "DealsWidgetLarge",
              "label": "Bey3a Deals (Large)",
              "description": "Today's hot deals expanded",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "OrderTrackingWidget",
              "label": "Bey3a Tracking",
              "description": "Track your order",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "OrderTrackingWidgetLarge",
              "label": "Bey3a Tracking (Large)",
              "description": "Detailed order tracking",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "RecommendationsWidget",
              "label": "Bey3a For You",
              "description": "Product recommendations",
              "minWidth": "110dp",
              "minHeight": "110dp",
              "targetCellWidth": 2,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            },
            {
              "name": "RecommendationsWidgetLarge",
              "label": "Bey3a For You (Large)",
              "description": "More recommendations",
              "minWidth": "250dp",
              "minHeight": "110dp",
              "targetCellWidth": 4,
              "targetCellHeight": 2,
              "updatePeriodMillis": 1800000
            }
          ]
        }
      ],
      "expo-asset"
    ]
  }
}
